# Copy this file to .env on the demo host and fill values.
# All values are optional except ANTHROPIC_API_KEY (only when AI_PROVIDER=Anthropic).

# AI provider: "Mock" (default, no network) or "Anthropic" (live model calls).
AI_PROVIDER=Anthropic

# Engage to short-circuit every AI invocation with a deterministic failure.
AI_KILL_SWITCH_ENGAGED=false

# Anthropic Messages API key. Required when AI_PROVIDER=Anthropic.
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# SQL Server sa password used by the demo SQL container.
SQL_SA_PASSWORD=CivicFlow!Passw0rd

# Public host exposed by your reverse proxy (Caddy/nginx/etc). Drives CORS.
CIVICFLOW_PUBLIC_HOST=waofm-demo.madewellrd.com
